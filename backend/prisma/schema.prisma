// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  projects     Project[] @relation("UserProjects") // projetos que ele é owner
  tasks        Task[]    @relation("UserTasks") // tarefas em que ele é assignee
  tasksOwned   Task[]    @relation("UserOwners") // ← Novo campo para tarefas onde ele é owner
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Project {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  owner   User @relation("UserProjects", fields: [ownerId], references: [id])
  ownerId Int

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  projectId   Int
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId Int?  @map("assigneeId")
  assignee   User? @relation("UserTasks", fields: [assigneeId], references: [id]) // ← User.tasks oposto

  ownerId Int
  owner   User @relation("UserOwners", fields: [ownerId], references: [id])

  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("tasks")
}
